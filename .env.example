# Core app
PORT=5050
SESSION_SECRET=replace-with-long-random-secret
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Spotify OAuth (optional but required for Spotify playback)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=https://your-public-domain/auth/spotify/callback

# Optional convenience when building redirect URI
# APP_BASE_URL=https://your-public-domain

# Gameplay
SONG_COOLDOWN_ROUNDS=4

# Optional AI integrations (disabled in current game flow)
# OPENROUTER_API_KEY=
# ELEVENLABS_API_KEY=
